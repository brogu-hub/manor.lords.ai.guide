# Gemini API key from Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Path to Manor Lords save folder on your Windows host
# Find it: Win+E → paste %USERPROFILE%\AppData\Local\ManorLords\Saved\SaveGames
SAVE_FOLDER=C:\Users\Light\AppData\Local\ManorLords\Saved\SaveGames

# Dashboard port
DASHBOARD_PORT=8080

# Primary Gemini model — "auto" detects the latest flash model from the API
# Or set a specific model like "gemini-3.1-flash-lite-preview"
PRIMARY_MODEL=auto
FALLBACK_MODEL=gemini-2.5-flash

# DeepEval self-healing (max retries on failed eval, score threshold 0-1)
MAX_EVAL_RETRIES=2
EVAL_THRESHOLD=0.6

# Context cache TTL in seconds (default 30 min)
CACHE_TTL_SECONDS=1800

# Steam Workshop guide IDs (comma-separated, add more as needed)
WORKSHOP_GUIDE_IDS=3427105626

# Session history max entries
SESSION_MAX_ENTRIES=10

# File watcher debounce
DEBOUNCE_SECONDS=2.0
